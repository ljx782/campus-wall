/* 详情页 - 手绘便利贴风格 */
.detail-page { background: #FFC93C; min-height: 100vh; padding: 24rpx; padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx); }

.d-card { background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 28rpx; box-shadow: 4rpx 4rpx 0 #1A1A2E; }

.d-header { display: flex; align-items: center; margin-bottom: 20rpx; }
.d-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; border: 3rpx solid #1A1A2E; background: #F7F9FC; margin-right: 16rpx; }
.d-meta { flex: 1; }
.d-name { font-size: 28rpx; font-weight: 800; color: #1A1A2E; display: block; }
.d-time { font-size: 22rpx; color: #4A4A5A; margin-top: 4rpx; display: block; font-weight: 600; }
.d-tag { font-size: 22rpx; font-weight: 800; padding: 6rpx 16rpx; border: 2rpx solid #1A1A2E; border-radius: 4rpx; }
.tag-confession { background: #FFB3C6; }
.tag-secondhand { background: #FFCC80; }
.tag-study { background: #A0C4FF; }
.tag-lostfound { background: #CAFFBF; }

.d-body { margin-bottom: 20rpx; }
.d-title { font-size: 36rpx; font-weight: 900; color: #1A1A2E; line-height: 50rpx; display: block; margin-bottom: 14rpx; }
.d-desc { font-size: 28rpx; color: #4A4A5A; line-height: 44rpx; display: block; white-space: pre-wrap; }

.d-confession { background: #FFB3C6; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 28rpx; }
.dc-to { font-size: 26rpx; font-weight: 800; color: #1A1A2E; display: block; margin-bottom: 12rpx; }
.dc-text { font-size: 32rpx; font-weight: 700; color: #1A1A2E; line-height: 48rpx; display: block; }
.dc-from { font-size: 24rpx; font-weight: 700; color: #1A1A2E; margin-top: 16rpx; display: block; text-align: right; }

.d-price-row { display: flex; align-items: center; gap: 14rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.d-price { font-size: 48rpx; font-weight: 900; color: #E85D04; }
.d-tag-s { font-size: 22rpx; font-weight: 800; color: #1A1A2E; background: #FFCC80; padding: 6rpx 14rpx; border: 2rpx solid #1A1A2E; border-radius: 4rpx; }
.d-blue { background: #A0C4FF; }

.d-lost-badge { display: inline-block; font-size: 24rpx; font-weight: 900; padding: 10rpx 20rpx; border: 3rpx solid #1A1A2E; border-radius: 4rpx; margin-bottom: 14rpx; }
.d-lost-badge.lost { background: #FFB3C6; }
.d-lost-badge.found { background: #CAFFBF; }

.d-info { margin: 16rpx 0; }
.di-row { display: flex; padding: 14rpx 0; border-bottom: 2rpx dashed #1A1A2E; }
.di-k { font-size: 26rpx; font-weight: 700; color: #4A4A5A; width: 120rpx; flex-shrink: 0; }
.di-v { font-size: 26rpx; font-weight: 800; color: #1A1A2E; }

.d-imgs { display: flex; gap: 14rpx; margin-top: 20rpx; flex-wrap: wrap; }
.d-img { width: 180rpx; height: 180rpx; border: 3rpx solid #1A1A2E; border-radius: 4rpx; background: #F7F9FC; }
.d-img-big { width: 100%; height: 360rpx; }

.d-footer { border-top: 2rpx dashed #1A1A2E; padding-top: 20rpx; }
.d-stat { display: flex; gap: 32rpx; margin-bottom: 20rpx; }
.d-stat text { font-size: 24rpx; font-weight: 700; color: #4A4A5A; }

.d-contact { background: #CAFFBF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 20rpx; display: flex; align-items: center; gap: 14rpx; }
.dc-label { font-size: 24rpx; font-weight: 800; color: #1A1A2E; }
.dc-val { font-size: 28rpx; font-weight: 900; color: #1A1A2E; flex: 1; }
.dc-hint { font-size: 20rpx; color: #4A4A5A; font-weight: 600; }

.d-empty { text-align: center; padding: 200rpx 0; color: #4A4A5A; font-size: 28rpx; font-weight: 600; }
.de-big { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
