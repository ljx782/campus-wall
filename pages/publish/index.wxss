/* 发布页 - 手绘便利贴风格 */
.publish-page { background: #FFC93C; min-height: 100vh; padding-bottom: calc(env(safe-area-inset-bottom) + 60rpx); }

.pub-header { position: relative; padding: 20rpx 32rpx 24rpx; }
.cloud-deco { position: absolute; font-size: 44rpx; }
.pub-title-box { position: relative; z-index: 1; }
.pub-title { font-size: 48rpx; font-weight: 900; color: #1A1A2E; display: block; }
.pub-line { width: 120rpx; height: 8rpx; background: #1A1A2E; margin-top: 10rpx; border-radius: 4rpx; }

/* 类型选择 */
.type-box { margin: 0 32rpx 24rpx; }
.box-label { font-size: 24rpx; font-weight: 700; color: #4A4A5A; margin-bottom: 12rpx; display: block; }
.type-row { display: flex; gap: 16rpx; }
.type-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; box-shadow: 3rpx 3rpx 0 #1A1A2E; }
.type-item.selected { box-shadow: 1rpx 1rpx 0 #1A1A2E; transform: translate(2rpx, 2rpx); }
.type-item text { font-size: 22rpx; font-weight: 700; color: #1A1A2E; margin-top: 8rpx; }
.color-block { width: 48rpx; height: 48rpx; border: 2rpx solid #1A1A2E; border-radius: 4rpx; }
.cb-pink { background: #FFB3C6; }
.cb-orange { background: #FFCC80; }
.cb-blue { background: #A0C4FF; }
.cb-green { background: #CAFFBF; }

/* 表单区 */
.form-area { position: relative; margin: 0 32rpx 40rpx; padding: 32rpx; border: 3rpx solid #1A1A2E; border-radius: 4rpx; box-shadow: 4rpx 4rpx 0 #1A1A2E; }
.note-confession { background: #FFB3C6; }
.note-secondhand { background: #FFCC80; }
.note-study { background: #A0C4FF; }
.note-lostfound { background: #CAFFBF; }

.form-tape { position: absolute; top: -14rpx; left: 50%; transform: translateX(-50%); width: 80rpx; height: 28rpx; opacity: 0.5; }
.tape-confession { background: #FF6B9D; }
.tape-secondhand { background: #E85D04; }
.tape-study { background: #3A86FF; }
.tape-lostfound { background: #06D6A0; }

.fg { margin-bottom: 28rpx; }
.fl { font-size: 28rpx; font-weight: 800; color: #1A1A2E; margin-bottom: 10rpx; display: block; }
.fr { color: #E85D04; }
.fh { font-size: 22rpx; color: #4A4A5A; font-weight: 600; }
.fi { width: 100%; height: 80rpx; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 0 20rpx; font-size: 28rpx; color: #1A1A2E; box-sizing: border-box; }
.ft { width: 100%; min-height: 160rpx; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 20rpx; font-size: 28rpx; color: #1A1A2E; box-sizing: border-box; }
.fp { display: flex; align-items: center; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 0 20rpx; height: 80rpx; font-size: 28rpx; color: #1A1A2E; }
.fp.ph { color: #888899; }

.img-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item { width: 140rpx; height: 140rpx; border: 3rpx solid #1A1A2E; border-radius: 4rpx; position: relative; background: #FFFFFF; }
.img-item image { width: 100%; height: 100%; }
.img-del { position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; background: #E85D04; color: #FFF; border: 2rpx solid #1A1A2E; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; font-weight: 700; }
.img-add { width: 140rpx; height: 140rpx; border: 3rpx dashed #1A1A2E; border-radius: 4rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(255,255,255,0.5); }
.ia-icon { font-size: 40rpx; color: #1A1A2E; font-weight: 700; }
.ia-txt { font-size: 20rpx; color: #4A4A5A; margin-top: 4rpx; font-weight: 600; }

.opt-row { display: flex; flex-wrap: wrap; gap: 14rpx; }
.opt { padding: 12rpx 24rpx; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; font-size: 26rpx; color: #4A4A5A; font-weight: 600; }
.opt.on { background: #1A1A2E; color: #FFFFFF; }

.price-wrap { display: flex; align-items: center; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding-right: 20rpx; }
.pw-y { font-size: 36rpx; font-weight: 900; color: #E85D04; padding: 0 16rpx; }
.pw-in { flex: 1; border: none !important; background: transparent !important; }

.pub-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #1A1A2E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: 4rpx;
  border: none;
  text-align: center;
  margin-top: 8rpx;
}
.pub-btn::after { border: none; }
.pub-btn:active { opacity: 0.85; }
.pub-notice { display: block; text-align: center; font-size: 22rpx; color: #4A4A5A; margin-top: 16rpx; font-weight: 600; }

/* 底部装饰 */
.pub-bottom { position: relative; height: 80rpx; margin-top: 20rpx; }
.pub-hill { position: absolute; bottom: 0; left: -20rpx; right: -20rpx; height: 60rpx; background: #1B998B; border-radius: 50% 50% 0 0; }
.pub-plant { position: absolute; bottom: 20rpx; font-size: 40rpx; z-index: 1; }
