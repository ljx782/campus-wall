<view class="list-page">
  <view class="search-bar">
    <view class="search-box" bind:tap="navToSearch">
      <t-icon prefix="wr" name="search" size="36rpx" color="#BDC3C7" />
      <text class="search-text">搜索推荐</text>
    </view>
  </view>

  <view class="list-header" wx:if="{{category}}">
    <text class="header-title">{{category}}</text>
    <text class="header-count">共 {{goodsList.length}} 件</text>
  </view>

  <view wx:if="{{goodsList.length === 0 && !loading}}" class="empty-wrap">
    <text class="empty-text">😕 暂无相关物品</text>
  </view>

  <view wx:else class="goods-grid">
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="_id" data-id="{{item._id}}" bind:tap="goDetail">
      <image class="goods-img" src="{{item.coverImage || '/images/demo1.png'}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" />
      <view class="goods-info">
        <text class="goods-title ellipsis-2">{{item.title}}</text>
        <view class="goods-bottom">
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-tip">
    <text>加载中...</text>
  </view>

  <t-toast id="t-toast" />
</view>