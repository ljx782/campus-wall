/* 列表页 — 苹果风格 */
.list-page { background: #F5F5F7; min-height: 100vh; }
.search-bar { padding: 24rpx 28rpx; background: #F5F5F7; position: sticky; top: 0; z-index: 100; }
.search-box { display: flex; align-items: center; background: #E8E8ED; border-radius: 40rpx; padding: 18rpx 28rpx; }
.search-text { margin-left: 14rpx; color: #AEAEB2; font-size: 30rpx; }
.list-header { padding: 28rpx 32rpx 14rpx; }
.header-title { font-size: 38rpx; font-weight: 800; color: #1D1D1F; letter-spacing: -0.5rpx; }
.header-count { font-size: 26rpx; color: #AEAEB2; margin-left: 16rpx; }

.goods-grid { display: flex; flex-wrap: wrap; padding: 0 20rpx; gap: 20rpx; padding-bottom: 60rpx; }
.goods-item {
  width: calc(50% - 10rpx); background: #FFFFFF;
  border-radius: 18rpx; overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}
.goods-img { width: 100%; height: 340rpx; border-radius: 18rpx 18rpx 0 0; }
.goods-info { padding: 20rpx 24rpx 24rpx; }
.goods-title { font-size: 30rpx; color: #1D1D1F; line-height: 42rpx; font-weight: 600; }
.goods-bottom { display: flex; justify-content: space-between; align-items: baseline; margin-top: 16rpx; }
.goods-price { display: flex; align-items: baseline; }
.price-symbol { font-size: 24rpx; color: #1D1D1F; font-weight: 700; }
.price-value { font-size: 38rpx; color: #1D1D1F; font-weight: 800; margin-left: 4rpx; letter-spacing: -1rpx; }
.condition-tag { font-size: 22rpx; color: #0071E3; background: #F0F7FF; padding: 6rpx 14rpx; border-radius: 10rpx; }
.empty-wrap { text-align: center; padding: 140rpx 0; }
.empty-text { font-size: 30rpx; color: #AEAEB2; }
