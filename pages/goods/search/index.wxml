<view class="search-page">
  <t-search
    t-class-input-container="t-class__input-container"
    t-class-input="t-search__input"
    value="{{searchValue}}"
    leftIcon=""
    bind:submit="handleSubmit"
    focus
  >
    <t-icon slot="left-icon" prefix="wr" name="search" size="40rpx" color="#bbb" />
  </t-search>

  <!-- 搜索历史 -->
  <view wx:if="{{historyWords.length > 0}}" class="history-section">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-btn" bindtap="handleClearHistory">清空</text>
    </view>
    <view class="history-list">
      <view
        class="history-tag"
        wx:for="{{historyWords}}"
        wx:key="*this"
        data-index="{{index}}"
        bindtap="handleHistoryTap"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty-history">
    <text class="empty-text">暂无搜索历史</text>
  </view>
</view>