.search-page {
  box-sizing: border-box;
  width: 100vw;
  min-height: 100vh;
  padding: 0 30rpx;
  background: #F5F5F7;
}

.search-page .t-class__input-container {
  height: 64rpx !important;
  border-radius: 32rpx !important;
}

.search-page .t-search__input {
  font-size: 28rpx !important;
  color: #333 !important;
}

/* 搜索历史 */
.history-section {
  margin-top: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.clear-btn {
  font-size: 24rpx;
  color: #0071e3;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  background: #fff;
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.empty-history {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #aeaeb2;
}