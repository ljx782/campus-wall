.favorites-page {
  min-height: 100vh;
  background: #F5F5F7;
}

.page-header {
  padding: 30rpx 24rpx 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.fav-list {
  padding: 0 24rpx;
}

.fav-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  position: relative;
}

.fav-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.fav-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.fav-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  line-height: 1.4;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fav-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.fav-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 700;
  color: #ff3b30;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff3b30;
}

.fav-condition {
  font-size: 22rpx;
  color: #8e8e93;
  background: #f5f5f7;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.fav-meta {
  margin-top: 8rpx;
}

.fav-publisher {
  font-size: 22rpx;
  color: #aeaeb2;
}

.fav-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.05);
  border-radius: 50%;
}

.fav-remove text {
  font-size: 24rpx;
  color: #8e8e93;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #aeaeb2;
  margin-top: 20rpx;
}