/* 编辑资料 - 手绘便利贴风格 */
.person-page { background: #FFC93C; min-height: 100vh; padding: 32rpx; padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx); }

.p-header { margin-bottom: 32rpx; }
.p-title { font-size: 44rpx; font-weight: 900; color: #1A1A2E; display: block; }
.p-line { width: 100rpx; height: 8rpx; background: #1A1A2E; margin-top: 10rpx; border-radius: 4rpx; }

.p-section { margin-bottom: 32rpx; }
.p-label { font-size: 28rpx; font-weight: 800; color: #1A1A2E; margin-bottom: 14rpx; display: block; }

.p-avatar-btn { width: 200rpx; height: 200rpx; padding: 0; margin: 0; background: transparent; border: none; position: relative; }
.p-avatar-btn::after { border: none; }
.p-avatar { width: 200rpx; height: 200rpx; border-radius: 50%; border: 4rpx solid #1A1A2E; background: #FFFFFF; box-shadow: 4rpx 4rpx 0 #1A1A2E; }
.p-tip { position: absolute; bottom: -6rpx; left: 50%; transform: translateX(-50%); font-size: 20rpx; color: #E85D04; background: #FFFFFF; border: 2rpx solid #1A1A2E; padding: 4rpx 12rpx; border-radius: 4rpx; white-space: nowrap; font-weight: 700; }

.p-input { width: 100%; height: 80rpx; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; padding: 0 20rpx; font-size: 30rpx; color: #1A1A2E; box-sizing: border-box; box-shadow: 3rpx 3rpx 0 #1A1A2E; }
.p-input::placeholder { color: #888899; }

.p-opts { display: flex; gap: 16rpx; }
.p-opt { padding: 14rpx 36rpx; background: #FFFFFF; border: 3rpx solid #1A1A2E; border-radius: 4rpx; font-size: 28rpx; font-weight: 700; color: #1A1A2E; box-shadow: 3rpx 3rpx 0 #1A1A2E; }
.p-opt.on { background: #1A1A2E; color: #FFFFFF; box-shadow: 1rpx 1rpx 0 #1A1A2E; transform: translate(2rpx, 2rpx); }

.p-save { width: 100%; height: 90rpx; line-height: 90rpx; background: #1A1A2E; color: #FFFFFF; font-size: 32rpx; font-weight: 800; border-radius: 4rpx; border: none; margin-top: 40rpx; box-shadow: 4rpx 4rpx 0 rgba(0,0,0,0.2); }
.p-save::after { border: none; }
.p-save:active { box-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.2); transform: translate(2rpx, 2rpx); }
